AGY_BIN=agy
AGY_CONTINUE=true
MODELS_FILE=models.yaml
AGY_TIMEOUT=300
# pasta onde o agy guarda as conversas (brain dir); vazio = ~/.gemini/antigravity-cli/brain
BRAIN_DIR=
# quantos processos agy podem rodar ao mesmo tempo — agy trava o banco local, manter em 1 é o seguro
AGY_MAX_CONCURRENT=1
# se definido, exige header "Authorization: Bearer <valor>" em /v1/*; vazio = sem auth
AGY_API_KEY=
